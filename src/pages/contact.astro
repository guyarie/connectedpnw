---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const contact = await getEntry('site', 'contact');
const c = contact.data;
---

<Base title={`${c.title} — Connected PNW`} description={c.description}>

  <div class="page-hero">
    <div class="container">
      {c.kicker && <p class="kicker">{c.kicker}</p>}
      {c.section_heading && <h1 style="max-width:none;font-size:var(--text-xl);">{c.section_heading}</h1>}
      {c.section_intro && <p class="lead" style="margin-top:var(--space-4);">{c.section_intro}</p>}
    </div>
  </div>

  <section>
    <div class="container" style="max-width:640px;">
      <div class="panel">
        <form
          method="POST"
          action={c.contact_form_action ?? '#'}
        >
          {/* Formspree config — keep hidden */}
          <input type="hidden" name="_subject" value="New interest list submission — Connected PNW" />
          {c.contact_redirect_url && <input type="hidden" name="_next" value={c.contact_redirect_url} />}
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div style="display:grid;gap:var(--space-5);">

            <div class="form-grid">
              <div class="form-field">
                <label for="first_name">First name</label>
                <input type="text" id="first_name" name="first_name" autocomplete="given-name" required />
              </div>
              <div class="form-field">
                <label for="last_name">Last name</label>
                <input type="text" id="last_name" name="last_name" autocomplete="family-name" required />
              </div>
            </div>

            <div class="form-field">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" autocomplete="email" required />
            </div>

            <div class="form-field">
              <label for="hear_about">How did you hear about Connected PNW?</label>
              <select id="hear_about" name="hear_about">
                <option value="">Select one…</option>
                <option value="friend">Friend or colleague</option>
                <option value="therapist">Therapist or coach</option>
                <option value="social">Social media</option>
                <option value="search">Web search</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-field">
              <label for="message">Anything you'd like us to know? <span class="muted">(optional)</span></label>
              <textarea id="message" name="message"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;">
              Join the interest list
            </button>

          </div>
        </form>
      </div>

      {c.contact_note && (
        <p class="muted" style="font-size:var(--text-sm);margin-top:var(--space-5);text-align:center;">
          {c.contact_note}
        </p>
      )}
    </div>
  </section>

</Base>
