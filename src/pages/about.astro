---
import Base from '../layouts/Base.astro';
import { getEntry } from 'astro:content';

const about = await getEntry('site', 'about');
const a = about.data;
---

<Base title={`${a.title} — Connected PNW`} description={a.section_intro}>

  <div class="page-hero">
    <div class="container">
      {a.kicker && <p class="kicker">{a.kicker}</p>}
      {a.section_heading && <h1 style="max-width:none;font-size:var(--text-xl);">{a.section_heading}</h1>}
      {a.section_intro && <p class="lead" style="margin-top:var(--space-4);">{a.section_intro}</p>}
    </div>
  </div>

  <section>
    <div class="container">
      {a.cards && (
        <div class="two-col">
          {a.cards.map((card) => (
            <article class="card">
              <h3>{card.heading}</h3>
              <p class="muted">{card.body}</p>
            </article>
          ))}
        </div>
      )}
      <div class="actions" style="margin-top:var(--space-10);">
        <a class="btn btn-primary" href="/contact">Get on the interest list</a>
        <a class="btn btn-secondary" href="/faq">Read the FAQ</a>
      </div>
    </div>
  </section>

</Base>
