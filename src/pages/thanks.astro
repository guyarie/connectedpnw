---
import Base from '../layouts/Base.astro';
---

<Base title="You're on the list — Connected PNW">
  <div class="page-hero" style="text-align:center;padding-bottom:clamp(4rem,8vw,7rem);">
    <div class="container" style="max-width:560px;">
      <div class="eyebrow" style="margin-bottom:var(--space-6);display:inline-flex;">Thank you</div>
      <h1 style="max-width:none;font-size:var(--text-xl);">You're on the interest list.</h1>
      <p class="lead" style="margin-inline:auto;">
        We'll be in touch when a new cohort opens. In the meantime, feel free to read more about the program below.
      </p>
      <div class="actions" style="justify-content:center;">
        <a class="btn btn-primary" href="/#journey">How the program works</a>
        <a class="btn btn-secondary" href="/faq">Read the FAQ</a>
      </div>
    </div>
  </div>
</Base>
