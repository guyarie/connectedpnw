---
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div>
      <a class="brand" href="/" style="font-size:var(--text-sm);">
        <div class="brand-mark" style="width:32px;height:32px;border-radius:9px;" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 7h5a5 5 0 0 1 0 10H7"></path>
            <path d="M17 17h-5a5 5 0 0 1 0-10h5"></path>
          </svg>
        </div>
        <span>Connected PNW</span>
      </a>
      <p style="margin:0.5rem 0 0;font-size:var(--text-xs);">
        &copy; {year} Connected PNW. All rights reserved.
      </p>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/#model">Coaching model</a>
      <a href="/#journey">Program journey</a>
      <a href="/about">About</a>
      <a href="/faq">FAQ</a>
