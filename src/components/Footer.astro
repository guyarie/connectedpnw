---
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div>
      <a class="brand" href="/">
        <img src="/images/website-logo-cropped.png" alt="Connected PNW" class="brand-logo" style="height:43px;" />
      </a>
      <p style="margin:0.5rem 0 0;font-size:var(--text-xs);">
        &copy; {year} Connected PNW. All rights reserved.
      </p>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/#journey">Program journey</a>
      <a href="/#model">Coaching model</a>
      <a href="/faq">FAQ</a>
      <a href="/blog/">Blog</a>
      <a href="/contact">Contact</a>
    </nav>

    <SocialLinks class="footer-social" />
  </div>
</footer>
